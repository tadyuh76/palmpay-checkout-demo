BETTER_AUTH_URL=http://localhost:7999
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Optional hosted Postgres. When set, Better Auth and the demo store use Neon/Postgres.
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Local fallback when DATABASE_URL is not set.
PALMPAY_DB_PATH=data/palmpay-demo.sqlite

# Optional Google OAuth
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
