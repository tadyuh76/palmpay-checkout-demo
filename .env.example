BETTER_AUTH_URL=http://localhost:7999
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Required shared database. Localhost, the NFC bridge target, and Vercel must use
# the same DATABASE_URL when they should record the same experiment data.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Disposable local-only fallback. Do not enable for real experiment runs.
# PALMPAY_ALLOW_SQLITE_FALLBACK=true
# PALMPAY_DB_PATH=data/palmpay-demo.sqlite

# Local NFC reader bridge. Set the same token in the app server and bridge process.
# PALMPAY_NFC_BRIDGE_TOKEN=replace-with-local-reader-token
# PALMPAY_APP_URL=http://localhost:7999
# PALMPAY_APP_URLS=http://localhost:7999,https://demo-experiment.vercel.app
# PALMPAY_NFC_CARD_REF=CARD-POS-042
# PALMPAY_NFC_CARD_MAP={"04AABBCCDD":"CARD-POS-042"}

# Local PalmPay palm vein SDK. The app auto-detects the bundled CameraSDK/run
# folder when PALMPAY_PALM_SDK_DIR is not set.
# PALMPAY_PALM_SDK_DIR=C:\path\to\CameraSDK\run
# SDK working directory for temporary palm template files. The app persists the
# active template bytes in DATABASE_URL and restores them here before scans.
# PALMPAY_PALM_TEMPLATE_DIR=data/palm-templates
# PALMPAY_PALM_SCAN_TIMEOUT_MS=45000
# PALMPAY_PALM_PYTHON=python
# PALMPAY_PALM_ALLOWED_ORIGINS=http://localhost:7999,https://demo-experiment.vercel.app
# NEXT_PUBLIC_PALMPAY_PALM_API_URL=http://localhost:7999

# Optional Google OAuth
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
